  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Spartha.World.NPCInteract
  npcName: Marta Delacroix
  dialogueLines:
  - Welcome to the Bayou, child. The spirits are restless tonight.
  - These Sparks... they're not just creatures. They're beings from the Resonance.
  - I've been sealing the tears Auralux left behind. But they keep coming back.
  - "Your bond with your Sparks \u2014 that's what anchors them here. Remember that."
  nameColor: {r: 1, g: 0.92156863, b: 0.015686275, a: 1}
